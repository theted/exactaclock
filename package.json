{
  "name": "exactaclock",
  "version": "1.0.0",
  "description": "GPS-based time correction application that displays corrected GMT time based on your exact coordinates",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "start": "npx http-server . -p 3003 -o --cors",
    "serve": "npx http-server . -p 3003 --cors",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "dev": "npx http-server . -p 3003 -o --cors",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js",
    "format:check": "prettier --check src/**/*.js",
    "help": "echo 'Available commands: npm start (run app), npm test (info about tests), npm run dev (development server), npm run lint (check code), npm run format (format code)'"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "timezone",
    "gps",
    "clock",
    "time",
    "location",
    "coordinates",
    "javascript",
    "html5"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "index.html",
  "repository": {
    "type": "git",
    "url": "."
  }
}
